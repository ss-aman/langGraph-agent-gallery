# ─────────────────────────────────────────────────────────
# LLM Configuration (provider-agnostic via init_chat_model)
# ─────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# API key for chosen provider (uncomment the one you need)
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# GOOGLE_API_KEY=your-google-key-here

# ─────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────
# CRITICAL: Change this in production! Use a 256-bit random secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-please-change-in-production-use-256bit-random
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────
DATABASE_PATH=./data/claims.db
# For production: replace aiosqlite with asyncpg + PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ─────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────
# Requests per minute per user (sustained)
RATE_LIMIT_RPM=10
# Maximum burst above sustained rate
RATE_LIMIT_BURST=20
# For production: set REDIS_URL to use Redis-backed rate limiting
# REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────
MAX_QUERY_LENGTH=500
MAX_RESULT_ROWS=50
LOG_LEVEL=INFO
